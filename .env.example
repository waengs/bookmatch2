# Required for NextAuth session encryption (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Auto-set on Vercel; for local dev use http://localhost:3000
AUTH_URL=http://localhost:3000

# Firebase client (from Firebase Console → Project settings → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin — option A: paste the full service account JSON (easiest on Vercel)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}

# Firebase Admin — option B: separate fields from the service account JSON
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional — enables Hardcover genre/mood search (https://hardcover.app/account/api)
HARDCOVER_API_TOKEN=

# Optional — higher Google Books rate limits
GOOGLE_BOOKS_API_KEY=
